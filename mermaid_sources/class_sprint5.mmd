classDiagram
    direction TB

    class AIService {
        <<FastAPI Service>>
        +chat(query, userId) ChatResponse
        +getRecommendations(userId) Plat[]
        +runForecasting(daysAhead) ForecastReport
        +optimizeKitchen(orders) Schedule
        +scanReceipt(image) InvoiceData
    }

    class Chatbot {
        <<RAG Engine>>
        -llm : GoogleGemini
        -embeddings : HuggingFace
        -vectorStore : FAISS
        +classifyIntent(query) Intent
        +retrieveContext(query, k) Document[]
        +generateResponse(context, query) String
        +refreshKnowledge() void
    }

    class RecommendationEngine {
        <<ML Module>>
        -cooccurrenceMatrix : Matrix
        +buildMatrix(orderHistory) void
        +getRecommendations(userId, n) Plat[]
        +computeSimilarity(platA, platB) Float
    }

    class ForecastingEngine {
        <<ML Module>>
        -alpha : Float
        -seasonalCoefficients : Float[]
        +trainModel(historicalData) void
        +predict(daysAhead) ForecastReport
        +decomposeIngredients(plats) IngredientReport
    }

    class KitchenOptimizer {
        <<Optimization Module>>
        +parseOrders(orders) Task[]
        +computeCriticalPath(tasks) Schedule
        +assignWorkstations(tasks) GanttChart
        +calculateMakespan() Duration
    }

    class OCREngine {
        <<Vision Module>>
        -model : GeminiVision
        +processImage(image) Text
        +extractStructuredData(text) InvoiceData
        +validateExtraction(data) Boolean
    }

    class VectorStore {
        <<FAISS Index>>
        -index : Float32
        -metadata : Json
        +addDocuments(docs) void
        +similaritySearch(vector, k) Document[]
        +deleteIndex() void
        +rebuildIndex() void
    }

    AIService "1" --> "1" Chatbot : utilise
    AIService "1" --> "1" RecommendationEngine : utilise
    AIService "1" --> "1" ForecastingEngine : utilise
    AIService "1" --> "1" KitchenOptimizer : utilise
    AIService "1" --> "1" OCREngine : utilise
    Chatbot "1" --> "1" VectorStore : interroge
