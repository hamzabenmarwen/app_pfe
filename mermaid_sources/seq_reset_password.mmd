sequenceDiagram
    actor Utilisateur
    participant UI as React Frontend
    participant Gateway as API Gateway
    participant Auth as Auth Service
    participant DB as PostgreSQL
    participant Mail as SMTP Service

    Utilisateur->>UI: Saisit son email
    UI->>Gateway: POST /auth/forgot-password
    Gateway->>Auth: Achemine la requête
    Auth->>DB: Vérifie si l'utilisateur existe
    
    alt Utilisateur trouvé
        Auth->>Auth: Génère PasswordResetToken (valide 1h)
        Auth->>DB: Sauvegarde le token
        Auth->>Mail: Envoie email avec lien de réinitialisation
        Mail-->>Auth: OK
    end
    
    %% On renvoie toujours 200 OK pour éviter l'énumération d'emails (sécurité)
    Auth-->>Gateway: 200 OK
    Gateway-->>UI: Succès
    UI-->>Utilisateur: "Si votre email existe, un lien a été envoyé"

    %% Deuxième phase : Réinitialisation
    Note over Utilisateur, DB: L'utilisateur clique sur le lien dans l'email
    
    Utilisateur->>UI: Saisit nouveau mot de passe
    UI->>Gateway: POST /auth/reset-password {token, newPassword}
    Gateway->>Auth: Achemine la requête
    Auth->>DB: Vérifie le token (existe ? expiré ?)
    
    alt Token invalide ou expiré
        Auth-->>Gateway: 400 Bad Request
        Gateway-->>UI: Erreur
        UI-->>Utilisateur: "Lien invalide ou expiré"
    else Token valide
        Auth->>Auth: Bcrypt: hache le nouveau mot de passe
        Auth->>DB: Met à jour l'utilisateur
        Auth->>DB: Supprime le token utilisé
        Auth-->>Gateway: 200 OK
        Gateway-->>UI: Succès
        UI-->>Utilisateur: "Mot de passe modifié avec succès"
    end
