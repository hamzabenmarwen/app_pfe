flowchart TD
    Start(( ))
    End((( )))

    PENDING(["Demande en attente"])
    QUOTED(["Devis envoyé"])
    CONFIRMED(["Événement confirmé"])
    IN_PROGRESS(["Événement en cours"])
    COMPLETED(["Événement terminé"])
    CANCELLED(["Événement annulé"])

    Start --> PENDING
    PENDING -->|Envoi devis par admin| QUOTED
    QUOTED -->|Acceptation devis par client| CONFIRMED
    QUOTED -->|Rejet devis par client| PENDING
    CONFIRMED -->|Début événement| IN_PROGRESS
    IN_PROGRESS -->|Fin événement| COMPLETED
    COMPLETED --> End
    PENDING -->|Annulation client| CANCELLED
    QUOTED -->|Annulation| CANCELLED
    CANCELLED --> End

    style Start fill:#000,stroke:#000,width:20px,height:20px
    style End fill:#fff,stroke:#000,stroke-width:4px,width:20px,height:20px
    style PENDING fill:#f0f0f0,stroke:#333,color:#000
    style QUOTED fill:#f0f0f0,stroke:#333,color:#000
    style CONFIRMED fill:#f0f0f0,stroke:#333,color:#000
    style IN_PROGRESS fill:#f0f0f0,stroke:#333,color:#000
    style COMPLETED fill:#f0f0f0,stroke:#333,color:#000
    style CANCELLED fill:#f0f0f0,stroke:#333,color:#000
