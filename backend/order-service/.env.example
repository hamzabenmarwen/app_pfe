# Order Service Configuration
PORT=3003
NODE_ENV=development

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5174

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/traiteurpro_orders"

# JWT Configuration
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-chars-long

# Flouci Payment Configuration (Tunisian payment gateway)
FLOUCI_APP_TOKEN=your-flouci-app-token
FLOUCI_APP_SECRET=your-flouci-app-secret
FLOUCI_WEBHOOK_SECRET=your-webhook-secret

# Email / Branding (used for PDF invoice generation; admin notifications go via auth-service)
FROM_EMAIL=your-email@gmail.com
FROM_NAME="Assiette Gala"

# Frontend URL
FRONTEND_URL=http://localhost:5174

# Inter-service URLs
AUTH_SERVICE_URL=http://localhost:3001
CATALOG_SERVICE_URL=http://localhost:3002

# Inter-service authentication
INTERNAL_SERVICE_TOKEN=your-internal-service-token

# Order business rules
ORDER_MIN_LEAD_HOURS=48
ORDER_MIN_AMOUNT_DT=30
ORDER_DELIVERY_FEE_DT=5
ORDER_TAX_RATE=0.19
ORDER_MAX_ORDERS_PER_DAY=0
ORDER_MAX_ORDERS_PER_SLOT=0
ORDER_ENFORCE_INGREDIENT_STOCK=true
