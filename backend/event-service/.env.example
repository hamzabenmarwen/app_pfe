# Event Service Configuration
PORT=3004
NODE_ENV=development

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5174

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/traiteurpro_events"

# JWT Configuration
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-chars-long

# Flouci Payment Configuration (for event invoices)
FLOUCI_APP_TOKEN=your-flouci-app-token
FLOUCI_APP_SECRET=your-flouci-app-secret

# Frontend URL
FRONTEND_URL=http://localhost:5174

# Event business rules
EVENT_MIN_LEAD_HOURS_FOR_QUOTE_REQUEST=48
EVENT_MAX_GUESTS_PER_DAY=0
EVENT_INVOICE_DUE_DAYS=7
