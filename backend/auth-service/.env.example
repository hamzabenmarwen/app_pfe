# Auth Service Configuration
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/traiteurpro_auth"

# JWT Configuration (min 32 characters)
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-chars-long
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=your-email@gmail.com
FROM_NAME="Assiette Gala"
ADMIN_EMAIL=admin@example.com

# OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id

# Security
BCRYPT_ROUNDS=12
AUTH_BYPASS_EMAIL_VERIFICATION=false
AUTH_REFRESH_COOKIE_NAME=ag_refresh_token
AUTH_REFRESH_COOKIE_PATH=/api/auth
AUTH_REFRESH_COOKIE_SAME_SITE=lax
AUTH_REFRESH_COOKIE_SECURE=false

# OTP security (rate limiting + anti-bruteforce)
OTP_VERIFY_RATE_WINDOW_MS=600000
OTP_VERIFY_RATE_MAX=8
OTP_RESEND_RATE_WINDOW_MS=900000
OTP_RESEND_RATE_MAX=3
OTP_FAILURE_WINDOW_MS=900000
OTP_FAILURE_MAX_ATTEMPTS=5
OTP_FAILURE_LOCK_MS=900000

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5174
